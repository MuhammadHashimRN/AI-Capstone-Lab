# =============================================================================
# .env.example — Runtime Secrets Template
# =============================================================================
# Copy this file to .env and fill in real values before running the container.
#
#   cp .env.example .env
#   # edit .env with your keys
#   docker compose up
#
# .env is listed in .dockerignore and must NEVER be committed to version
# control.  All values here are placeholders — no real credentials.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Groq LLM API key — get a free key at https://console.groq.com
# The agent will refuse to start if this is missing.
GROQ_API_KEY=gsk_replace_with_your_real_groq_api_key

# ── Optional ──────────────────────────────────────────────────────────────────

# LangSmith trace observability — get a key at https://smith.langchain.com
# Leave blank to disable tracing (the agent runs fine without it).
LANGSMITH_API_KEY=lsv2_pt_replace_with_your_real_langsmith_key

# LangSmith project name — all traces are grouped under this name.
LANGCHAIN_PROJECT=inventory-reorder-agent

# ── How secrets are injected at runtime ──────────────────────────────────────
#
# docker compose reads this file via the implicit env_file discovery:
#   docker compose --env-file .env up
#
# The compose file passes values into the agent container using:
#   environment:
#     - GROQ_API_KEY=${GROQ_API_KEY}
#     - LANGSMITH_API_KEY=${LANGSMITH_API_KEY:-}
#
# config.py reads them with:
#   GROQ_API_KEY = os.environ.get("GROQ_API_KEY", "")
#
# No value is ever hardcoded in config.py, Dockerfile, or main.py.
# The image built by `docker compose build` contains NO credentials.
